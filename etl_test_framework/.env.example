# ETL Test Framework — Environment Variables
# Copy to .env and fill in values. Never commit .env to source control.

ETL_ENV=dev

# Source DB
SOURCE_DB_HOST=localhost
SOURCE_DB_NAME=etl_source
SOURCE_DB_USER=etl_user
SOURCE_DB_PASS=your_secure_password

# Target DB
TARGET_DB_HOST=localhost
TARGET_DB_NAME=etl_target
TARGET_DB_USER=etl_user
TARGET_DB_PASS=your_secure_password
